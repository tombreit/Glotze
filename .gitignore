/target

# Local meson build directory (`meson setup build`); the flatpak path uses its
# own build dir inside .flatpak-builder.
/build/

# Vendored flatpak helper, re-downloaded by scripts/update-cargo-sources.sh
# (cache filename embeds the pinned generator commit, hence the glob).
/scripts/flatpak-cargo-generator*.py

# Local flatpak-builder output: the workdir, its cache, the per-build OSTree
# repo, and any single-file bundle produced by `flatpak build-bundle`.
/build-dir
/.flatpak-builder
/repo
*.flatpak

# Output of build-aux/test-live.sh (per-run logs + screenshots).
/test-live-out/

# Generated Flathub submission manifest + cargo-sources copy, pinned to a release
# tag by scripts/gen-flathub-manifest.sh. Transient: regenerate per release and
# copy into the flathub/<app-id> repo (see PUBLISHING.md). The script is the
# source of truth, not this output.
/build-aux/flathub/

# rustfmt backup files (when invoked with --backup).
*.rs.bk

# gettext .pot template, regenerated by `meson compile -C build glotze-pot`.
# The .po files in po/ are the authoritative source for translations.
/po/glotze.pot

# Editor / OS noise that has no place in the repo.
/.vscode/
/.idea/
.DS_Store
Thumbs.db
