<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.tombreit.Glotze</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>EUPL-1.2</project_license>
  <name>Glotze</name>
  <summary>Search and download public broadcaster Mediatheken (DACH region)</summary>
  <description>
    <p>
      Glotze is a GNOME-native desktop client for searching videos across ARD, ZDF, 3sat, arte and
      the other German public broadcasters via the MediathekViewWeb API. Episodes can be downloaded
      to the local Videos folder for offline viewing.
    </p>
    <p>
      Playback and streaming are intentionally out of scope — Glotze hands you the file and steps
      out of the way.
    </p>
    <p>Features:</p>
    <ul>
      <li>Search the combined MediathekViewWeb catalogue across every German public broadcaster</li>
      <li>Choose a download quality — low, medium or high — per result</li>
      <li>Download episodes to your Videos folder with a live progress indicator</li>
      <li>Per-broadcaster channel logos for quick visual scanning of results</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.tombreit.Glotze.desktop</launchable>
  <developer id="io.github.tombreit">
    <name>tombreit</name>
  </developer>
  <update_contact>tombreit_at_gmail.com</update_contact>
  <url type="homepage">https://github.com/tombreit/Glotze</url>
  <url type="bugtracker">https://github.com/tombreit/Glotze/issues</url>
  <url type="vcs-browser">https://github.com/tombreit/Glotze</url>
  <url type="donation">https://ko-fi.com/thmsde</url>
  <content_rating type="oars-1.1" />
  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Network</category>
  </categories>
  <keywords>
    <keyword>ARD</keyword>
    <keyword>ZDF</keyword>
    <keyword>Mediathek</keyword>
    <keyword>arte</keyword>
    <keyword>broadcast</keyword>
  </keywords>
  <!--
    Screenshots live in data/screenshots/ (see the README there). Flathub mirrors
    these HTTPS URLs at build time; it does not host the images, so each URL must
    resolve when the manifest is reviewed. Exactly one screenshot is type="default"
    (the Flathub hero image).
  -->
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/tombreit/Glotze/main/data/screenshots/glotze-main-view.png</image>
      <caption>Main Glotze view</caption>
    </screenshot>
  </screenshots>
